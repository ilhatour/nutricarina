# Carina Batista Nutricionista — cache control (mata a pegadinha do CDN Hostinger)
<IfModule mod_headers.c>
  <FilesMatch "\.(html|css|js|xml|txt|json)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
  <FilesMatch "\.(png|jpg|jpeg|gif|svg|webp|ico|woff2?)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# HTTPS + www→raiz + URLs limpas (sem .html)
<IfModule mod_rewrite.c>
  RewriteEngine On

  # força HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]
  # www → raiz
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

  # /index.html → /
  RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
  RewriteRule ^ / [R=301,L]
  # /qualquer.html → /qualquer (301, remove a extensão)
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]
  # servir a página sem extensão: /blog → blog.html (interno)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}\.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

ErrorDocument 404 /404.html
